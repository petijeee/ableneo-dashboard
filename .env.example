# Notion Integration Token
# Vytvor integration na: https://www.notion.so/my-integrations
# Potom pridaj integration ku tvojej Marketing Plan stránke (Share → Add connections)
NOTION_TOKEN=secret_xxx

# Notion Database ID — databáza bola vytvorená, toto je jej ID:
NOTION_DB_ID=37ef1c72a99d46ec9be372259c79c5a1

# Server port
PORT=3000

# ── LinkedIn (auto-fetch KR2, L1, L2) ────────────────────────────────
# 1. Create app at https://developer.linkedin.com/apps
# 2. Add "Community Management API" product (r_organization_social scope)
# 3. Run: python scripts/linkedin_auth.py
LINKEDIN_CLIENT_ID=your_client_id
LINKEDIN_CLIENT_SECRET=your_client_secret
LINKEDIN_ORG_ID=your_org_numeric_id   # from linkedin.com/company/<id>/admin/
LINKEDIN_ACCESS_TOKEN=                # auto-written by linkedin_auth.py
